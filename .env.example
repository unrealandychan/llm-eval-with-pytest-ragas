# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Eval settings
RAGAS_THRESHOLD_FAITHFULNESS=0.7
RAGAS_THRESHOLD_ANSWER_RELEVANCY=0.7
RAGAS_THRESHOLD_CONTEXT_RECALL=0.7

# Set to "mock" to run tests without real API calls
LLM_EVAL_MODE=mock
